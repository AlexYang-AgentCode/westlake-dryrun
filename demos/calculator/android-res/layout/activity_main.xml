<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#222222"
    android:padding="16dp">

    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="48sp"
        android:textColor="#FFFFFF"
        android:background="#333333"
        android:padding="24dp"
        android:gravity="end"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <Button android:id="@+id/btn7" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="7" android:textSize="24sp" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btn8" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="8" android:textSize="24sp" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btn9" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="9" android:textSize="24sp" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btnDiv" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="/" android:textSize="24sp" android:background="#FF9800" android:textColor="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <Button android:id="@+id/btn4" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="4" android:textSize="24sp" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btn5" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="5" android:textSize="24sp" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btn6" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="6" android:textSize="24sp" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btnMul" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="x" android:textSize="24sp" android:background="#FF9800" android:textColor="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <Button android:id="@+id/btn1" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="1" android:textSize="24sp" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btn2" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="2" android:textSize="24sp" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btn3" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="3" android:textSize="24sp" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btnSub" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="-" android:textSize="24sp" android:background="#FF9800" android:textColor="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnC" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="C" android:textSize="24sp" android:background="#F44336" android:textColor="#FFFFFF" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btn0" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="0" android:textSize="24sp" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btnEq" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="=" android:textSize="24sp" android:background="#4CAF50" android:textColor="#FFFFFF" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/btnAdd" android:layout_width="0dp" android:layout_height="64dp" android:layout_weight="1" android:text="+" android:textSize="24sp" android:background="#FF9800" android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
